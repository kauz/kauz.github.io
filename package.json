{
  "name": "kauz-portfolio",
  "type": "module",
  "version": "0.4.2",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "cp .github/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit"
  },
  "lint-staged": {
    "*.{ts,js,mjs,astro}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@resvg/resvg-js": "2.6.2",
    "astro": "6.1.10",
    "lil-gui": "0.21.0",
    "satori": "0.26.0",
    "suncalc": "1.9.0",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/suncalc": "1.9.2",
    "@types/three": "0.184.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-astro": "1.7.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "typescript-eslint": "8.59.1"
  }
}
