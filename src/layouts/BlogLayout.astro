---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
}
const { title, date } = Astro.props;
const dateStr = date.toISOString().slice(0, 10);
---

<BaseLayout title={`${title} — apopov.dev`}>
  <div class="blog-wrap">
    <a class="back" href={`${import.meta.env.BASE_URL}blog/`} id="back-link">← blog</a>
    <article>
      <header class="post-header">
        <h1>{title}</h1>
        <time datetime={dateStr}>{dateStr}</time>
      </header>
      <div class="prose">
        <slot />
      </div>
    </article>
  </div>

  <script>
    document.addEventListener('keydown', (e) => {
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
      if (e.key === 'Backspace') {
        e.preventDefault();
        window.location.href = (document.getElementById('back-link') as HTMLAnchorElement).href;
      } else if (e.key === 'PageUp') {
        e.preventDefault();
        window.location.href = import.meta.env.BASE_URL;
      }
    });
  </script>
</BaseLayout>
