---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
}
const { title, date } = Astro.props;
const dateStr = date.toISOString().slice(0, 10);
---

<BaseLayout title={`${title} — apopov.dev`}>
  <div class="blog-wrap">
    <a class="back" href={import.meta.env.BASE_URL}>← back to terminal</a>
    <article>
      <header class="post-header">
        <h1>{title}</h1>
        <time datetime={dateStr}>{dateStr}</time>
      </header>
      <div class="prose">
        <slot />
      </div>
    </article>
  </div>
</BaseLayout>
