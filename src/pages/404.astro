---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/404.css';
---

<BaseLayout title="404 — Signal Lost in the Outer Rim">
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400..900&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div id="loader">
    <div class="loader-ring"></div>
    <div class="loader-text">ACQUIRING SIGNAL…</div>
  </div>

  <div id="ui">
    <div id="main-content">
      <div class="tag-404">404</div>
      <h1>SIGNAL LOST<br />IN THE<br />OUTER RIM</h1>
      <div class="cta-group">
        <a href="/" class="btn btn-primary">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="1.3em"
            fill="currentColor"
            version="1.0"
            viewBox="0 0 100 100"
            ><path
              d="M53.2 1.6c-10.2 2.7-19.7 9-30.2 20C11.3 33.9 4.8 44.8 1.5 57.7c-2 7.9-1.7 17.6.6 18.1 1.3.2 1.7-1.1 2.2-8 .3-4.6 1.4-10.9 2.5-14C12.8 37 29 20.9 44.8 16c14.7-4.6 24.3-1 27.3 10.1 1.1 4 1 5.6-.5 11.2C68.9 47.1 59.1 61 54.8 61c-2.8 0-2.2-1.7 2.6-7.8C63 46.1 65 41.4 65 35.5c0-8.9-5.5-14.7-13.9-14.7-12 0-27.5 13.2-36.4 31-3.6 7.4-4.1 9.3-4.5 17-.3 7.1 0 9.7 1.7 14.4 7.2 18.9 28.5 22.2 50.6 7.8 11.7-7.6 26.2-24.5 32-37.3 5.5-11.8 7.3-28.7 3.3-29.5-1.6-.3-1.8.5-1.8 5.5C96 51.3 78.9 74.9 57.5 83c-8.1 3-18.5 3.2-23.9.4-11.6-6-9.6-22.9 4.6-38.8 4.7-5.3 7-6.7 8.2-4.7.3.5-1.2 3.1-3.4 5.9-5.4 6.8-8 12.7-8 18.7 0 13.4 11.4 18.7 24.9 11.4 8.9-4.7 19.9-16.7 25.3-27.5 3.7-7.6 4.2-9.4 4.6-17.2.3-7.1 0-9.7-1.7-14.4C82.8 2.9 69.7-2.9 53.2 1.6"
            ></path></svg
          >
          <span>RETURN TO BASE</span></a
        >
      </div>
    </div>

    <div id="bottom-bar">
      <button id="sound-btn">
        <span class="sound-icon">🔇</span>
        <span class="sound-label">SOUND: OFF</span>
      </button>
    </div>
  </div>

  <div id="way-text">THIS IS THE WAY.</div>

  <script>
    import '../scripts/404/404.ts';
  </script>
</BaseLayout>
