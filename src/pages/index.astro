---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const postData = posts.map((p) => ({
  slug: p.id,
  title: p.data.title,
  date: p.data.date.toISOString().slice(0, 10),
  description: p.data.description ?? '',
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>apopov.dev</title>
    <link rel="icon" type="image/png" href="/assets/favicon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#111111" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="apple-touch-icon" href="/assets/pwa-192.png" />
  </head>
  <body>
    <div class="t-win">
      <div class="t-bar">
        <span class="t-title">apopov@dev: ~</span>
        <div class="t-btns">
          <span
            class="t-btn"
            onclick="  window.resizeTo(window.screen.availWidth / 2, window.screen.availHeight / 2)"
            >─</span
          >
          <span
            class="t-btn"
            onclick="document.fullscreenElement ? document.exitFullscreen() : document.documentElement.requestFullscreen()"
            >□</span
          >
          <span class="t-btn" onclick="window.close()">✕</span>
        </div>
      </div>

      <div class="t-body" id="t-body">
        <div id="terminal" data-posts={JSON.stringify(postData)}>
          <div id="output"></div>
          <div class="input-row">
            <span id="prompt" class="prompt">apopov.dev:~$</span>
            <span id="cmd-typed"></span><span class="cursor" id="blink-cursor"></span>
          </div>
        </div>
      </div>
    </div>

    <input
      id="cmd-input"
      type="text"
      autocomplete="off"
      autocorrect="off"
      autocapitalize="off"
      spellcheck="false"
      autofocus
      aria-label="Terminal input"
    />

    <script>
      import { boot } from '../lib/app';
      await boot();
    </script>
  </body>
</html>
