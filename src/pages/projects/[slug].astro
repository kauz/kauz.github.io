---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import JsonLd from '../../components/JsonLd.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const backHref = `${import.meta.env.BASE_URL}projects/`;
const base = Astro.site?.toString().replace(/\/$/, '') ?? 'https://kauz.github.io';
const projectUrl = `${base}/projects/${project.id}`;
const ogImage = `/og/projects/${project.id}.png`;

const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  name: project.data.title,
  ...(project.data.description && { description: project.data.description }),
  dateCreated: project.data.date.toISOString().slice(0, 10),
  url: projectUrl,
  image: `${base}${ogImage}`,
  ...(project.data.url && { codeRepository: project.data.url }),
  ...(project.data.tech?.length && { programmingLanguage: project.data.tech }),
  author: { '@type': 'Person', name: 'Artem Popov', url: base },
};
---

<BlogLayout
  title={project.data.title}
  date={project.data.date}
  description={project.data.description}
  backHref={backHref}
  backLabel="← projects"
  ogImage={ogImage}
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />
    <JsonLd schema={jsonLd} />
  </Fragment>
  {
    project.data.tech && project.data.tech.length > 0 && (
      <p class="post-tech">{project.data.tech.join(' · ')}</p>
    )
  }
  {
    project.data.url && (
      <p>
        <a href={project.data.url} target="_blank" rel="noopener">
          ↗ {project.data.url}
        </a>
      </p>
    )
  }
  <Content />
</BlogLayout>
